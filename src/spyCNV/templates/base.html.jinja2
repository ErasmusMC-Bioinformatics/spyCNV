<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{{ sample_id }}</title>
        <style>
         body { margin: 0; font-family: sans-serif; }
         #visualization { width: 100%; height: 100vh; }
        </style>
    </head>
    <body>
        <h1>{{ sample_id }}</h1>
        <div id="visualization"></div>
        <script type="text/javascript" src="static/genome-spy_core@0.64.x.js"></script>
        <script type="text/javascript" src="plots/ideogramTrack.js"></script>
        <script type="text/javascript" src="plots/geneAnnotationTrack.js"></script>
        <script>
         const spec = {
             "genome": { "name": "hg19" },
             "vconcat": [
                 ideogramTrack("hg19"),
                 geneAnnotationTrack("hg19")
             ]
         };

         genomeSpyEmbed.embed(document.getElementById("visualization"), spec);
        </script>
    </body>

</html>
